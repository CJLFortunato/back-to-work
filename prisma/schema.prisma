generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int @default(autoincrement()) @id
  name                String @db.VarChar(50)
  email               String @unique @db.VarChar(100)
  password            String @db.VarChar(100)
  insertion_date      DateTime @default(now()) 	@db.Timestamptz(3)
  last_connexion      DateTime? 	@db.Timestamptz(3)
  applications        Application[]
  @@map(name: "users")
}

model Application {
  id                  Int @default(autoincrement()) @id
  job_title           String @db.VarChar(100)
  company             String? @db.VarChar(100)
  contract_type       String? @db.VarChar(50)
  location            String? @db.VarChar(50)
  salary_min          Float?
  salary_max          Float?
  notes               String?
  status              String @db.VarChar(50)
  hired               Boolean?
  closure_date        DateTime? 	@db.Timestamptz(3)
  archival_date       DateTime? 	@db.Timestamptz(3)
  insertion_date      DateTime @default(now()) 	@db.Timestamptz(3)
  active              Boolean
  user                User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id             Int
  tags                Tag[]
  interviews          Interview[]
  contacts            Contact[]
  @@map(name: "applications")
}

model Tag {
  id                  Int @default(autoincrement()) @id
  label               String @db.VarChar(50)
  insertion_date      DateTime @default(now()) 	@db.Timestamptz(3)
  active              Boolean
  archival_date       DateTime? 	@db.Timestamptz(3)
  applications        Application[]
  @@map(name: "tags")
}

model Interview {
  id                  Int @default(autoincrement()) @id
  label               String @db.VarChar(50)
  insertion_date      DateTime @default(now()) 	@db.Timestamptz(3)
  interviewer         String? @db.VarChar(100)
  notes               String?
  application         Application   @relation(fields: [application_id], references: [id], onDelete: Cascade)
  application_id      Int
  @@map(name: "interviews")
}

model Contact {
  id                  Int @default(autoincrement()) @id
  label               String @db.VarChar(50)
  insertion_date      DateTime @default(now()) 	@db.Timestamptz(3)
  contactee           String? @db.VarChar(100)
  means               String? @db.VarChar(100)
  notes               String?
  application         Application   @relation(fields: [application_id], references: [id], onDelete: Cascade)
  application_id      Int
  @@map(name: "contacts")
}